# ============================================================
# WordPress Core — no necesita versionarse, lo gestiona WP
# ============================================================
wp-admin/
wp-includes/

# Archivos de arranque del core (se reinstalan con WP)
wp-activate.php
wp-blog-header.php
wp-comments-post.php
wp-cron.php
wp-links-opml.php
wp-load.php
wp-login.php
wp-mail.php
wp-settings.php
wp-signup.php
wp-trackback.php
wp-config-sample.php
xmlrpc.php
license.txt
readme.html
default.php

# ============================================================
# Credenciales y configuración sensible
# ============================================================
wp-config.php
.env
.env.*
.private/

# ============================================================
# Uploads y archivos generados
# ============================================================
wp-content/uploads/
wp-content/upgrade/
wp-content/backup-migration/
wp-content/ai-assistant-cache/

# Cache (LiteSpeed y otros)
wp-content/cache/
wp-content/litespeed/

# ============================================================
# Temas base (solo el child theme es código custom)
# ============================================================
wp-content/themes/astra/
wp-content/themes/twentytwentyfive/
wp-content/themes/twentytwentyfour/
wp-content/themes/twentytwentythree/

# ============================================================
# Sistema operativo y editores
# ============================================================
.DS_Store
Thumbs.db
.vscode/sftp.json
*.log

# Claude Code — configuración local de la máquina del dev
.claude/settings.local.json

# index.php placeholders de WP (no aportan nada)
wp-content/index.php
wp-content/themes/index.php
wp-content/plugins/index.php
